# SwiftFormat — https://github.com/nicklockwood/SwiftFormat
# Local: `swiftformat --lint .`  |  fix: `swiftformat .`
# Pre-commit: see `.githooks/pre-commit`

--swiftversion 6.0
--indent 4
--tabwidth 4
--maxwidth 120
--wraparguments before-first
--wrapparameters before-first
--wrapcollections before-first
--trimwhitespace always
--insertlines enabled
--removelines enabled
--allman false
--elseposition same-line
--guardelse next-line
--emptybraces spaced
--commas always
--semicolons never
--stripunusedargs always
--ifdef no-indent
--importgrouping alphabetized
--self remove
--header strip

--exclude build,DerivedData,.build,.swiftpm
